# Daily Stock Analysis — environment
# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required.

# LLM (required) — Claude Sonnet via Anthropic
ANTHROPIC_API_KEY=

# Optional news enrichment (falls back to yfinance free news if unset)
TAVILY_API_KEY=

# Optional: Finnhub for fundamentals (free tier, 60 calls/min)
# FINNHUB_API_KEY=

# Output
# Email notify is OFF until SMTP vars are set
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=
